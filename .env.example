# .env.example
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to ".env" and fill in your API keys.
# Jarvis loads .env automatically if python-dotenv is installed.
# Never commit .env to git -- it's already in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# Gemini (Google AI Studio -> https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Day 7: Live Weather (free API from https://openweathermap.org/api)
# 1. Sign up at https://home.openweathermap.org/users/sign_up
# 2. Go to API keys tab -> copy your Default key
# 3. Paste it below (no quotes needed)
# ─────────────────────────────────────────────────────────────────────────────
OPENWEATHER_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# After adding your keys, set providers in config.py:
#   AI_PROVIDER  = "gemini"   # or "openai"
#   WEATHER_CITY = "Hyderabad"
# ─────────────────────────────────────────────────────────────────────────────
